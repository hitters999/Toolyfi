<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Text Trimmer - Remove Spaces, Trim & Clean Text | Free Tool</title>
  <meta name="description" content="Free online text trimmer and cleaner. Remove extra spaces, trim whitespace, remove line breaks, clean text data instantly. No sign-up required.">
  <meta name="keywords" content="text trimmer, trim text, remove spaces, clean text, text cleaner, whitespace remover">
  <meta name="author" content="Toolyfi">
  <meta name="robots" content="index, follow">
  <meta name="theme-color" content="#667eea">
  
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      padding: 20px;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      background: white;
      border-radius: 20px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
      overflow: hidden;
    }

    .header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 40px 30px;
      text-align: center;
    }

    .header h1 {
      font-size: 2.5em;
      margin-bottom: 10px;
      font-weight: 800;
    }

    .header p {
      font-size: 1.05em;
      opacity: 0.95;
      margin-bottom: 15px;
    }

    .badges {
      display: flex;
      gap: 10px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .badge {
      background: rgba(255,255,255,0.2);
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 0.85em;
      font-weight: 600;
    }

    .content {
      padding: 40px 30px;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 15px;
      margin-bottom: 30px;
    }

    .stat-box {
      background: #f8f9ff;
      padding: 15px;
      border-radius: 10px;
      border-left: 4px solid #667eea;
      text-align: center;
    }

    .stat-label {
      color: #999;
      font-size: 0.85em;
      margin-bottom: 8px;
    }

    .stat-value {
      font-size: 1.8em;
      font-weight: 800;
      color: #667eea;
    }

    .controls {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 30px;
      justify-content: center;
    }

    .btn {
      padding: 12px 25px;
      border: none;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
      font-size: 0.95em;
    }

    .btn-primary {
      background: #667eea;
      color: white;
    }

    .btn-primary:hover {
      background: #5568d3;
      transform: translateY(-2px);
      box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
    }

    .btn-secondary {
      background: #f0f0f0;
      color: #333;
      border: 2px solid #ddd;
    }

    .btn-secondary:hover {
      background: #e0e0e0;
    }

    .options {
      background: #f8f9ff;
      padding: 20px;
      border-radius: 12px;
      margin-bottom: 30px;
      border: 2px solid #e0e0e0;
    }

    .option-title {
      font-weight: 700;
      color: #333;
      margin-bottom: 15px;
      font-size: 1.05em;
    }

    .option-group {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 15px;
    }

    .checkbox-item {
      display: flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
    }

    .checkbox-item input[type="checkbox"] {
      cursor: pointer;
      width: 18px;
      height: 18px;
      accent-color: #667eea;
    }

    .checkbox-item label {
      cursor: pointer;
      flex: 1;
      font-weight: 500;
      color: #333;
    }

    .editor-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 20px;
    }

    .editor-section {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .editor-label {
      font-weight: 700;
      color: #333;
      font-size: 1.05em;
    }

    textarea {
      flex: 1;
      padding: 15px;
      border: 2px solid #e0e0e0;
      border-radius: 10px;
      font-family: 'Courier New', monospace;
      font-size: 0.9em;
      resize: vertical;
      min-height: 350px;
      transition: all 0.3s;
    }

    textarea:focus {
      outline: none;
      border-color: #667eea;
      box-shadow: 0 0 15px rgba(102, 126, 234, 0.2);
    }

    textarea:read-only {
      background: #f8f9ff;
      color: #555;
    }

    .message {
      padding: 15px 20px;
      border-radius: 8px;
      margin-bottom: 20px;
      display: none;
      font-weight: 500;
    }

    .message.show {
      display: block;
    }

    .message.success {
      background: #efe;
      color: #3c3;
      border-left: 4px solid #3c3;
    }

    .message.error {
      background: #fee;
      color: #c33;
      border-left: 4px solid #c33;
    }

    .footer {
      background: #f8f9fa;
      padding: 30px;
      text-align: center;
      color: #666;
      border-top: 1px solid #eee;
      font-size: 0.95em;
    }

    .footer a {
      color: #667eea;
      text-decoration: none;
      font-weight: 600;
    }

    @media (max-width: 1024px) {
      .editor-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 768px) {
      .header {
        padding: 25px 15px;
      }

      .header h1 {
        font-size: 1.8em;
      }

      .content {
        padding: 20px 15px;
      }

      textarea {
        min-height: 250px;
      }

      .option-group {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>

<div class="container">
  <div class="header">
    <h1>✂️ Text Trimmer & Cleaner</h1>
    <p>Remove extra spaces, trim whitespace, and clean text instantly</p>
    <div class="badges">
      <span class="badge">💰 100% Free</span>
      <span class="badge">⚡ Instant</span>
      <span class="badge">🔧 Advanced</span>
      <span class="badge">🔒 Secure</span>
    </div>
  </div>

  <div class="content">
    <!-- STATS -->
    <div class="stats">
      <div class="stat-box">
        <div class="stat-label">Characters</div>
        <div class="stat-value" id="inputChars">0</div>
      </div>
      <div class="stat-box">
        <div class="stat-label">Words</div>
        <div class="stat-value" id="inputWords">0</div>
      </div>
      <div class="stat-box">
        <div class="stat-label">Lines</div>
        <div class="stat-value" id="inputLines">0</div>
      </div>
      <div class="stat-box">
        <div class="stat-label">Saved</div>
        <div class="stat-value" id="charsSaved">0</div>
      </div>
    </div>

    <!-- MESSAGE -->
    <div class="message" id="message"></div>

    <!-- OPTIONS -->
    <div class="options">
      <div class="option-title">🔧 Trimming Options</div>
      <div class="option-group">
        <div class="checkbox-item">
          <input type="checkbox" id="trimSpaces" checked onchange="trimText()">
          <label for="trimSpaces">Remove Extra Spaces</label>
        </div>
        <div class="checkbox-item">
          <input type="checkbox" id="removeNewlines" onchange="trimText()">
          <label for="removeNewlines">Remove Line Breaks</label>
        </div>
        <div class="checkbox-item">
          <input type="checkbox" id="removeEmpty" onchange="trimText()">
          <label for="removeEmpty">Remove Empty Lines</label>
        </div>
        <div class="checkbox-item">
          <input type="checkbox" id="trimLeading" checked onchange="trimText()">
          <label for="trimLeading">Trim Leading/Trailing</label>
        </div>
        <div class="checkbox-item">
          <input type="checkbox" id="lowercase" onchange="trimText()">
          <label for="lowercase">Convert to Lowercase</label>
        </div>
        <div class="checkbox-item">
          <input type="checkbox" id="uppercase" onchange="trimText()">
          <label for="uppercase">Convert to Uppercase</label>
        </div>
        <div class="checkbox-item">
          <input type="checkbox" id="capitalize" onchange="trimText()">
          <label for="capitalize">Capitalize Words</label>
        </div>
        <div class="checkbox-item">
          <input type="checkbox" id="removeSpecial" onchange="trimText()">
          <label for="removeSpecial">Remove Special Chars</label>
        </div>
      </div>
    </div>

    <!-- CONTROLS -->
    <div class="controls">
      <button class="btn btn-primary" onclick="trimText()">✂️ Trim</button>
      <button class="btn btn-secondary" onclick="clearAll()">🗑️ Clear</button>
      <button class="btn btn-secondary" onclick="copyOutput()">📋 Copy</button>
      <button class="btn btn-secondary" onclick="loadSample()">📌 Sample</button>
    </div>

    <!-- EDITOR -->
    <div class="editor-grid">
      <div class="editor-section">
        <label class="editor-label">📥 Input Text</label>
        <textarea id="inputText" placeholder="Paste or type your text here..." oninput="updateStats()"></textarea>
      </div>
      <div class="editor-section">
        <label class="editor-label">📤 Output Text</label>
        <textarea id="outputText" placeholder="Trimmed text will appear here..." readonly></textarea>
      </div>
    </div>
  </div>

  <div class="footer">
    <p>🚀 Made with ❤️ by <a href="https://toolyfi.com">Toolyfi</a></p>
    <p>100% Free • No Sign-up • No Data Storage • Instant Processing</p>
  </div>
</div>

<!-- JAVASCRIPT -->
<script>
  const inputText = document.getElementById('inputText');
  const outputText = document.getElementById('outputText');
  const messageEl = document.getElementById('message');

  function updateStats() {
    const text = inputText.value;
    document.getElementById('inputChars').textContent = text.length;
    document.getElementById('inputWords').textContent = text.trim().split(/\s+/).filter(w => w).length;
    document.getElementById('inputLines').textContent = text.split('\n').length;
  }

  function trimText() {
    try {
      let text = inputText.value;
      const originalLength = text.length;

      // Trim leading and trailing spaces
      if (document.getElementById('trimLeading').checked) {
        text = text.trim();
      }

      // Remove extra spaces
      if (document.getElementById('trimSpaces').checked) {
        text = text.replace(/\s+/g, ' ');
      }

      // Remove line breaks
      if (document.getElementById('removeNewlines').checked) {
        text = text.replace(/\n/g, ' ');
      }

      // Remove empty lines
      if (document.getElementById('removeEmpty').checked) {
        text = text.split('\n').filter(line => line.trim()).join('\n');
      }

      // Convert to lowercase
      if (document.getElementById('lowercase').checked) {
        text = text.toLowerCase();
      }

      // Convert to uppercase
      if (document.getElementById('uppercase').checked) {
        text = text.toUpperCase();
      }

      // Capitalize words
      if (document.getElementById('capitalize').checked) {
        text = text.replace(/\b\w/g, char => char.toUpperCase());
      }

      // Remove special characters
      if (document.getElementById('removeSpecial').checked) {
        text = text.replace(/[^\w\s]/g, '');
      }

      outputText.value = text;
      
      const savedChars = originalLength - text.length;
      document.getElementById('charsSaved').textContent = Math.max(0, savedChars);
      
      showMessage('✓ Text trimmed successfully!', 'success');
    } catch (e) {
      showMessage(`✗ Error: ${e.message}`, 'error');
    }
  }

  function clearAll() {
    inputText.value = '';
    outputText.value = '';
    updateStats();
    document.getElementById('charsSaved').textContent = '0';
    messageEl.classList.remove('show');
  }

  function copyOutput() {
    if (!outputText.value) {
      showMessage('Nothing to copy!', 'error');
      return;
    }
    navigator.clipboard.writeText(outputText.value).then(() => {
      showMessage('✓ Copied to clipboard!', 'success');
    });
  }

  function loadSample() {
    inputText.value = `  This    is    a   sample   text  
    with multiple spaces   and   line   breaks.
    
    It has    empty    lines    too.
    This is useful for data cleaning!  `;
    updateStats();
    showMessage('📌 Sample text loaded!', 'success');
  }

  function showMessage(msg, type) {
    messageEl.textContent = msg;
    messageEl.className = 'message show ' + type;
    setTimeout(() => messageEl.classList.remove('show'), 3000);
  }

  // Initialize stats
  updateStats();
</script>

</body>
</html>
